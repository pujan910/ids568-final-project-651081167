  },
  "description": "OPT-125m LLM Inference Server — production monitoring dashboard. Tracks latency (split cached vs cold), throughput, errors, cache effectiveness, batch size, prompt-length drift signal, and host resources. Import into Grafana and select your Prometheus datasource scraping the FastAPI /metrics endpoint defined in dashboards/prometheus.yml.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "PROMETHEUS_DS"},
      "description": "End-to-end /generate latency in seconds, split by cache hit vs miss. p50/p95/p99 are computed via histogram_quantile.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "seconds",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": {"legend": false, "tooltip": false, "viz": false},
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": {"type": "linear"},
            "showPoints": "never",
            "spanNulls": false,
            "stacking": {"group": "A", "mode": "none"},
            "thresholdsStyle": {"mode": "off"}
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 5},
              {"color": "red", "value": 10}
            ]
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 0},
      "id": 1,
      "options": {
        "legend": {"calcs": ["mean", "lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(llm_request_latency_seconds_bucket{cached=\"false\"}[5m])) by (le))",
          "legendFormat": "p50 cold",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(llm_request_latency_seconds_bucket{cached=\"false\"}[5m])) by (le))",
          "legendFormat": "p95 cold",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(llm_request_latency_seconds_bucket{cached=\"false\"}[5m])) by (le))",
          "legendFormat": "p99 cold",
          "refId": "C"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(llm_request_latency_seconds_bucket{cached=\"true\"}[5m])) by (le))",
          "legendFormat": "p99 cached",
          "refId": "D"
        }
      ],
      "title": "Request Latency — Cached vs Cold (p50 / p95 / p99)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "PROMETHEUS_DS"},
      "description": "Successful and errored requests per second over the last 5 minutes.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisLabel": "req/s",
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2,
            "showPoints": "never"
          },
          "mappings": [],
          "thresholds": {"mode": "absolute", "steps": [{"color": "green"}]},
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 0},
      "id": 2,
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {"expr": "sum(rate(llm_requests_total{status=\"success\"}[5m]))", "legendFormat": "success", "refId": "A"},
        {"expr": "sum(rate(llm_requests_total{status=\"error\"}[5m]))", "legendFormat": "error", "refId": "B"}
      ],
      "title": "Throughput & Error Rate",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "PROMETHEUS_DS"},
      "description": "Cache hits as a fraction of total cache lookups. A sustained drop is the leading indicator for workload drift.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [],
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "orange", "value": 0.3},
              {"color": "yellow", "value": 0.5},
              {"color": "green", "value": 0.7}
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 9},
      "id": 3,
      "options": {
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "sum(rate(llm_cache_hits_total[5m])) / (sum(rate(llm_cache_hits_total[5m])) + sum(rate(llm_cache_misses_total[5m])))",
          "legendFormat": "hit rate",
          "refId": "A"
        }
      ],
      "title": "Cache Hit Rate",
      "type": "gauge"
    },
    {
      "datasource": {"type": "prometheus", "uid": "PROMETHEUS_DS"},
      "description": "Histogram of request batch sizes. If batches rarely fill (concentrated at low values), the batcher is timeout-bound and would benefit from a longer timeout under higher QPS.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisLabel": "batches",
            "drawStyle": "bars",
            "fillOpacity": 80,
            "lineWidth": 1
          },
          "mappings": [],
          "thresholds": {"mode": "absolute", "steps": [{"color": "green"}]}
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 9},
      "id": 4,
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom"},
        "tooltip": {"mode": "single"}
      },
      "targets": [
        {
          "expr": "sum(increase(llm_batch_size_bucket[5m])) by (le)",
          "format": "heatmap",
          "legendFormat": "{{le}}",
          "refId": "A"
        }
      ],
      "title": "Batch Size Distribution",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "PROMETHEUS_DS"},
      "description": "Distribution of incoming prompt length. A rightward shift is the canonical workload-drift signal — see Component 4 (drift-diagnostic-report.md).",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisLabel": "requests",
            "drawStyle": "bars",
            "fillOpacity": 80,
            "lineWidth": 1
          }
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 9},
      "id": 5,
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom"},
        "tooltip": {"mode": "single"}
      },
      "targets": [
        {
          "expr": "sum(increase(llm_prompt_length_chars_bucket[5m])) by (le)",
          "legendFormat": "{{le}}",
          "refId": "A"
        }
      ],
      "title": "Prompt Length Distribution (drift signal)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "PROMETHEUS_DS"},
      "description": "Process CPU, host memory, and concurrent in-flight requests.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisLabel": "%",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 80},
              {"color": "red", "value": 90}
            ]
          },
          "unit": "percent"
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "active requests"},
            "properties": [{"id": "unit", "value": "short"}]
          }
        ]
      },
      "gridPos": {"h": 9, "w": 24, "x": 0, "y": 17},
      "id": 6,
      "options": {
        "legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {"expr": "llm_cpu_percent", "legendFormat": "CPU %", "refId": "A"},
        {"expr": "llm_memory_percent", "legendFormat": "Memory %", "refId": "B"},
        {"expr": "llm_active_requests", "legendFormat": "active requests", "refId": "C"}
      ],
      "title": "System Resources",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
